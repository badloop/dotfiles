#!/usr/bin/env bash
# gitfind-current — Show the top N largest blobs in the current HEAD.
#
# Usage: gitfind-current [options] [count]
# Output: Interactive gum table (default) or plain text for piping.
#
# Options:
#   -p, --plain    Output raw data: <size_bytes> <object_hash> <path>
#   -n, --count N  Number of results (default: 50)
#   -h, --help     Show this help
#
# Examples:
#   gitfind-current                    # interactive table, top 50
#   gitfind-current -n 20             # interactive table, top 20
#   gitfind-current -p | gitpurge     # pipe to purge

set -euo pipefail

plain=false
count=50

while [[ $# -gt 0 ]]; do
  case "$1" in
    -p|--plain) plain=true; shift ;;
    -n|--count) count="$2"; shift 2 ;;
    -h|--help) sed -n '2,/^$/s/^# //p' "$0"; exit 0 ;;
    [0-9]*) count="$1"; shift ;;
    *) echo "Unknown option: $1" >&2; exit 1 ;;
  esac
done

# Auto-detect: fall back to plain if stdout is not a terminal
if [[ "$plain" == false ]] && ! [[ -t 1 ]]; then
  plain=true
fi

human_size() {
  local bytes=$1
  if (( bytes >= 1073741824 )); then
    printf "%.1f GB" "$(echo "scale=1; $bytes/1073741824" | bc)"
  elif (( bytes >= 1048576 )); then
    printf "%.1f MB" "$(echo "scale=1; $bytes/1048576" | bc)"
  elif (( bytes >= 1024 )); then
    printf "%.1f KB" "$(echo "scale=1; $bytes/1024" | bc)"
  else
    printf "%d B" "$bytes"
  fi
}

extension() {
  local path="$1"
  local base="${path##*/}"
  if [[ "$base" == *.* ]]; then
    echo ".${base##*.}"
  else
    echo "(none)"
  fi
}

raw=$(git ls-tree -r -l HEAD \
  | grep -v package-lock.json \
  | grep -v CHANGELOG.md \
  | awk '{print $4, $3, $5}' \
  | sort -nr \
  | head -"$count") || {
  rc=$?
  # 141 = SIGPIPE from head closing early — expected and harmless
  if (( rc != 141 )); then
    exit "$rc"
  fi
}

if [[ -z "$raw" ]]; then
  echo "No blobs found in HEAD."
  exit 0
fi

if [[ "$plain" == true ]]; then
  echo "$raw"
  exit 0
fi

# Build CSV for gum table
table="Size,Ext,Name,Path"
while IFS= read -r line; do
  bytes=$(echo "$line" | awk '{print $1}')
  path=$(echo "$line" | awk '{for(i=3;i<=NF;i++) printf "%s%s", $i, (i<NF?" ":""); print ""}')
  ext=$(extension "$path")
  name="${path##*/}"
  size=$(human_size "$bytes")
  table+=$'\n'"${size},${ext},${name},${path}"
done <<< "$raw"

echo "$table" | gum table \
  --separator "," \
  --columns "Size,Ext,Name,Path" \
  --widths 10,8,30,0 \
  --height 40 \
  --border rounded \
  --header.foreground "212" \
  --selected.foreground "10"
