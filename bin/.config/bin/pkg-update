#!/usr/bin/env bash

# echo -e "\e[32m\nUpdate system packages\e[0m"
# echo "sudo pacman -Syu --noconfirm --ignore \"$(omarchy-pkg-ignored)\""
# sudo pacman -Syu --noconfirm --ignore "$(omarchy-pkg-ignored)"

if aur-accessible; then
    echo -e "\e[32m\nUpdate AUR packages\e[0m"
    echo "yay -Syu --noconfirm"
    yay -Syu --noconfirm
    echo
else
    echo -e "\e[31m\nAUR is unavailable (so skipping updates)\e[0m"
    echo
fi

orphans=$(pacman -Qtdq)
if [[ -n "$orphans" ]]; then
    echo -e "\e[32m\nRemove orphan system packages\e[0m"
    while read -r pkg; do
        sudo pacman -Rs --noconfirm "$pkg" || true
    done <<< "$orphans"
    echo
fi

if [ "$(uname -r | sed 's/-arch/\.arch/')" != "$(pacman -Q linux | awk '{print $2}')" ]; then
    gum confirm "Linux kernel has been updated. Reboot?" && sudo reboot now
fi
