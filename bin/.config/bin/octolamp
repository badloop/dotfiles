#!/usr/bin/env bash
set -euo pipefail

# --- Configuration ---
WLED_IP="${WLED_IP:?WLED_IP environment variable must be set}"
API_URL="http://${WLED_IP}/json/state"

wled_post() {
  if curl -sf -X POST -H "Content-Type: application/json" -d "$1" "$API_URL" -o /dev/null --connect-timeout 3; then
    return 0
  else
    echo "Error communicating with WLED at ${WLED_IP}"
    exit 1
  fi
}

usage() {
  cat <<EOF
Usage: $(basename "$0") <command> [value]

Commands:
  power <on|off>        Turn the lamp on or off
  brightness <0-100>    Set brightness (0-100%)
  scene <name>          Apply a named scene

Scenes:
  synthwave             Neon pink/cyan/purple fading flow
  sunset                Warm orange/magenta/red gradient
  ocean                 Deep blue/teal/cyan waves
  campfire              Flickering warm amber/orange
  chill                 Slow pastel breathing
  off                   Fade to black and power off
EOF
  exit 1
}

[[ $# -lt 1 ]] && usage

# --- Scene definitions ---
# Each scene: turns on, sets brightness, configures segment(s) with colors + effect
# WLED effects reference (0-indexed, varies by firmware):
#   0=Solid, 1=Blink, 2=Breathe, 8=Colorloop, 9=Rainbow, 47=Gradient,
#   63=Palette, 69=Twinklefox, 76=Fade, 101=Flow, 110=Blends
# Colors are [R,G,B] arrays in the segment

apply_scene() {
  local scene="${1,,}"
  case "$scene" in
    synthwave)
      # Neon magenta, violet purple, cyan accent — swirly synthwave
      wled_post '{
        "on": true,
        "bri": 180,
        "transition": 20,
        "seg": [{
          "id": 0,
          "col": [[255,0,120],[180,0,255],[0,180,210]],
          "fx": 28,
          "sx": 66,
          "ix": 128,
          "pal": 0
        }]
      }'
      echo "Synthwave mode activated"
      ;;
    sunset)
      # Warm orange, deep magenta, soft red — slow gradient
      wled_post '{
        "on": true,
        "bri": 200,
        "transition": 20,
        "seg": [{
          "id": 0,
          "col": [[255,60,0],[200,0,80],[255,20,20]],
          "fx": 47,
          "sx": 40,
          "ix": 220,
          "pal": 0
        }]
      }'
      echo "Sunset mode activated"
      ;;
    ocean)
      # Deep blue, teal, bright cyan — wave-like motion
      wled_post '{
        "on": true,
        "bri": 160,
        "transition": 20,
        "seg": [{
          "id": 0,
          "col": [[0,20,180],[0,120,120],[0,200,255]],
          "fx": 101,
          "sx": 50,
          "ix": 180,
          "pal": 0
        }]
      }'
      echo "Ocean mode activated"
      ;;
    campfire)
      # Warm amber, orange, dark red — fire flicker effect
      wled_post '{
        "on": true,
        "bri": 200,
        "transition": 10,
        "seg": [{
          "id": 0,
          "col": [[255,100,0],[255,40,0],[180,10,0]],
          "fx": 66,
          "sx": 100,
          "ix": 180,
          "pal": 0
        }]
      }'
      echo "Campfire mode activated"
      ;;
    chill)
      # Soft lavender, mint, warm white — slow breathe
      wled_post '{
        "on": true,
        "bri": 120,
        "transition": 30,
        "seg": [{
          "id": 0,
          "col": [[180,140,255],[140,255,200],[255,220,180]],
          "fx": 2,
          "sx": 30,
          "ix": 240,
          "pal": 0
        }]
      }'
      echo "Chill mode activated"
      ;;
    off)
      # Graceful fade out
      wled_post '{"transition": 30, "bri": 0}'
      sleep 3
      wled_post '{"on": false}'
      echo "Faded to off"
      ;;
    *)
      echo "Unknown scene: $scene"
      echo "Available: synthwave, sunset, ocean, campfire, chill, off"
      exit 1
      ;;
  esac
}

# --- Main dispatch ---
mod_type="${1,,}"
shift

case "$mod_type" in
  power)
    [[ $# -ne 1 ]] && usage
    value="${1,,}"
    case "$value" in
      on)  wled_post '{"on":true}';  echo "WLED power on" ;;
      off) wled_post '{"on":false}'; echo "WLED power off" ;;
      *)   echo "Error: for 'power', value must be 'on' or 'off'."; exit 1 ;;
    esac
    ;;
  brightness)
    [[ $# -ne 1 ]] && usage
    value="$1"
    if ! [[ "$value" =~ ^[0-9]+$ ]] || (( value < 0 || value > 100 )); then
      echo "Error: for 'brightness', value must be an integer 0-100."
      exit 1
    fi
    bri=$(( value * 255 / 100 ))
    wled_post "{\"bri\":${bri}}"
    echo "WLED brightness set to ${value}%"
    ;;
  scene)
    [[ $# -ne 1 ]] && usage
    apply_scene "$1"
    ;;
  *)
    echo "Unknown command: $mod_type"
    usage
    ;;
esac
